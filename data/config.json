{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily (All)",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending",
        "fetch_limit": 15
      },
      {
        "name": "GitHub Trending - Python",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/python.xml",
        "enabled": true,
        "category": "github-trending",
        "fetch_limit": 10
      },
      {
        "name": "arXiv - AI",
        "url": "https://arxiv.org/rss/cs.AI",
        "enabled": true,
        "category": "paper-ai",
        "fetch_limit": 10
      },
      {
        "name": "arXiv - Machine Learning",
        "url": "https://arxiv.org/rss/cs.LG",
        "enabled": true,
        "category": "paper-ai",
        "fetch_limit": 10
      },
      {
        "name": "arXiv - NLP",
        "url": "https://arxiv.org/rss/cs.CL",
        "enabled": true,
        "category": "paper-ai",
        "fetch_limit": 10
      },
      {
        "name": "arXiv - Computer Vision",
        "url": "https://arxiv.org/rss/cs.CV",
        "enabled": true,
        "category": "paper-cs",
        "fetch_limit": 10
      },
      {
        "name": "arXiv - Data Science & Statistics",
        "url": "https://arxiv.org/rss/stat.ML",
        "enabled": true,
        "category": "paper-data-science",
        "fetch_limit": 10
      },
      {
        "name": "MIT Technology Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "ai-news",
        "fetch_limit": 10
      },
      {
        "name": "VentureBeat AI",
        "url": "https://venturebeat.com/category/ai/feed/",
        "enabled": true,
        "category": "ai-news",
        "fetch_limit": 10
      },
      {
        "name": "Yahoo Finance",
        "url": "https://finance.yahoo.com/news/rssindex",
        "enabled": true,
        "category": "finance",
        "fetch_limit": 15
      },
      {
        "name": "MarketWatch",
        "url": "https://feeds.content.dowjones.io/public/rss/mw_marketpulse",
        "enabled": true,
        "category": "finance",
        "fetch_limit": 15
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": false,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": false,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled": false,
      "users": [
        "karpathy",
        "roifex"
      ],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 7.5,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
